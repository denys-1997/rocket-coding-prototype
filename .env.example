APP_NAME=RocketCoding
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# For production:
# DB_CONNECTION=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_DATABASE=rocket_coding
# DB_USERNAME=rocket
# DB_PASSWORD=secret

QUEUE_CONNECTION=sync
# For production: redis, with Supervisor-managed workers on the 'llm' queue.
# REDIS_HOST=redis
# REDIS_PORT=6379

CACHE_STORE=file
SESSION_DRIVER=file

# --- LLM providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

LLM_PRIMARY_MODEL=claude-opus-4-7
LLM_FALLBACK_ENABLED=true
LLM_FALLBACK_MODEL=gpt-4o
LLM_MAX_RETRIES=2
LLM_TIMEOUT_SECONDS=60

# --- AWS (Textract for OCR, production only) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
